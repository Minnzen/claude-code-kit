{
  "name": "@claude-code-kit/agent",
  "version": "0.3.1",
  "description": "Headless agent framework for claude-code-kit — LLM query loop, tool execution, multi-provider",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src/"
  },
  "dependencies": {
    "zod": ">=3.20.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openai": ">=4.0.0",
    "zod-to-json-schema": ">=3.20.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "zod-to-json-schema": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openai": "*",
    "tsup": "*",
    "typescript": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Minnzen/claude-code-kit.git",
    "directory": "packages/agent"
  },
  "homepage": "https://github.com/Minnzen/claude-code-kit",
  "bugs": "https://github.com/Minnzen/claude-code-kit/issues",
  "keywords": [
    "agent",
    "llm",
    "claude",
    "openai",
    "tool-use",
    "ai"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
