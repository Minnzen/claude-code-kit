{
  "name": "@claude-code-kit/ui",
  "version": "0.3.1",
  "description": "Terminal UI component library for claude-code-kit — Spinner, ProgressBar, Divider and more",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src/"
  },
  "dependencies": {
    "@claude-code-kit/ink-renderer": "workspace:*",
    "@claude-code-kit/shared": "workspace:*",
    "chalk": "*",
    "chokidar": "*",
    "figures": "*",
    "marked": "*",
    "strip-ansi": "*",
    "usehooks-ts": "^3.1.1",
    "zod": ">=3.20.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "@claude-code-kit/agent": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@claude-code-kit/agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@claude-code-kit/agent": "workspace:*",
    "@types/marked": "*",
    "react": "*",
    "tsup": "*",
    "typescript": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Minnzen/claude-code-kit.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/Minnzen/claude-code-kit",
  "bugs": "https://github.com/Minnzen/claude-code-kit/issues",
  "keywords": [
    "terminal",
    "cli",
    "tui",
    "react",
    "components",
    "repl",
    "select",
    "spinner",
    "claude-code",
    "ai-agent"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
